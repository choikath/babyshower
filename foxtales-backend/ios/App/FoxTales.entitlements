<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Universal Links for the full app on /p/* (matches the AASA `applinks`
         section served at /.well-known/apple-app-site-association). -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:foxtales.app</string>
    </array>
</dict>
</plist>
