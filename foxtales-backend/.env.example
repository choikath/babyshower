# ── FoxTales backend configuration ───────────────────────────────────────────
# Copy to `.env` and fill in. The defaults below run a zero-dependency local
# demo (in-memory DB + local disk storage). Production uses Supabase.

NODE_ENV=development
PORT=8080

# The public HTTPS origin your cards point at. Tokens are written to tags as
# `${PUBLIC_BASE_URL}/p/<token>`. In prod this is your real domain.
PUBLIC_BASE_URL=http://localhost:8080

# ── Database ─────────────────────────────────────────────────────────────────
# memory   = in-process, no external services (demo/tests)
# postgres = Supabase Postgres (production) — set DATABASE_URL below
DB_DRIVER=memory
# Use the Supabase *connection pooler* string (port 6543) for serverless/containers:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Storage ──────────────────────────────────────────────────────────────────
# local    = local disk, HMAC-signed URLs served by this app (demo)
# supabase = private Supabase Storage bucket + signed URLs (production)
STORAGE_DRIVER=local
AUDIO_BUCKET=audio
SIGNED_URL_TTL_SEC=600          # signed media URL lifetime (10 min, spec 1.1)

# Supabase (required when DB_DRIVER=postgres or STORAGE_DRIVER=supabase)
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # SERVER ONLY — never ship to a client
# SUPABASE_JWT_SECRET=<project jwt secret>       # verifies access tokens (Settings > API)

# Local dev storage
LOCAL_MEDIA_DIR=./.media
LOCAL_SIGNING_SECRET=dev-only-insecure-secret-change-me

# ── Universal Link / App Clip association (spec 1.2) ─────────────────────────
APPLE_TEAM_ID=TEAMID
IOS_BUNDLE_ID=app.foxtales.ios
APPCLIP_BUNDLE_ID=app.foxtales.ios.Clip
# ITUNES_APP_ID=0000000000      # numeric App Store id — enables the Safari Smart App Banner

# ── Networking / dev ─────────────────────────────────────────────────────────
TRUST_PROXY=1                   # number of proxies/CDNs in front (for correct client IP)

# Dev-only: skip Supabase JWT verification so /api/* is testable locally.
# MUST be false in production.
DEV_BYPASS_AUTH=false
DEV_USER_ID=00000000-0000-0000-0000-0000000000aa
# DEV_SEED=true                 # with DB_DRIVER=memory, seeds a test family at boot
