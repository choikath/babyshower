<?xml version="1.0" encoding="UTF-8"?>
<!-- Example keys for the App Clip target's Info.plist. Merge into the target's
     generated plist (don't replace it wholesale). -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Keeps audio playing when the screen locks. Validate this works inside an
         App Clip on a real device (see NowPlaying.swift — the load-bearing spike). -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- App Clip marker. Xcode adds NSAppClip when you create the App Clip target;
         shown here for reference. -->
    <key>NSAppClip</key>
    <dict>
        <key>NSAppClipRequestEphemeralUserNotification</key>
        <false/>
        <key>NSAppClipRequestLocationConfirmation</key>
        <false/>
    </dict>
</dict>
</plist>
